{
  "name": "maestro-mcp",
  "version": "0.1.0",
  "description": "MCP server for mobile E2E testing via Maestro — auto-generates and runs YAML test flows on emulators and physical devices",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "maestro-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx src/__tests__/run.ts"
  },
  "keywords": ["mcp", "maestro", "mobile-testing", "e2e", "emulator", "automation"],
  "author": "jmartinez@autored.cl",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0"
  }
}
